// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model TipoUsuario {
  id        Int       @id @default(autoincrement())
  nomeTipo  String    @map("nome_tipo") @db.VarChar(50)
  usuarios  Usuario[]

  @@map("tiposusuario")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(100)
  senha     String   @db.VarChar(255)
  tipoId    Int      @map("tipo_id")
  telefone  String?  @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tipo                TipoUsuario      @relation(fields: [tipoId], references: [id])
  destinatarios       Destinatario[]
  encomendas          Encomenda[]      @relation("EncomendaFuncionario")
  encomendasRecebidas Encomenda[]      @relation("EncomendaDestinatario")
  notificacoes        Notificacao[]
  auditorias          Auditoria[]
  historicosAlterados HistoricoStatus[]
  autorizacoesCriadas Autorizacao[]

  @@map("usuario")
}

// ---------------------------------------------------------------------------
// REMETENTES
// ---------------------------------------------------------------------------

model Remetente {
  id        Int           @id @default(autoincrement())
  nome      String        @db.VarChar(100)
  tipo      TipoRemetente
  site      String?       @db.VarChar(255)
  createdAt DateTime      @default(now()) @map("created_at")

  encomendas Encomenda[]

  @@map("remetentes")
}

enum TipoRemetente {
  correios
  transportadora
  ecommerce
  outro

  @@map("tipo_remetente")
}

// ---------------------------------------------------------------------------
// ENCOMENDAS
// ---------------------------------------------------------------------------

model StatusEncomenda {
  id          Int    @id @default(autoincrement())
  nomeStatus  String @map("nome_status") @db.VarChar(50)
  descricao   String @db.VarChar(255)

  encomendas  Encomenda[]
  historicos  HistoricoStatus[]

  @@map("statusencomenda")
}

model Encomenda {
  id                   Int       @id @default(autoincrement())
  codigoRastreio       String?   @map("codigo_rastreio") @db.VarChar(50)
  remetenteId          Int?      @map("remetente_id")
  descricao            String?   @db.VarChar(255)
  funcionarioId        Int       @map("funcionario_id")
  destinatarioUsuarioId Int      @map("destinatario_usuario_id")
  statusAtualId        Int       @map("status_atual_id")
  dataEntrega          DateTime? @map("data_entrega")
  observacoes          String?   @db.Text
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  remetente   Remetente?      @relation(fields: [remetenteId], references: [id])
  funcionario Usuario         @relation("EncomendaFuncionario", fields: [funcionarioId], references: [id])
  destinatario Usuario        @relation("EncomendaDestinatario", fields: [destinatarioUsuarioId], references: [id])
  statusAtual StatusEncomenda @relation(fields: [statusAtualId], references: [id])

  historicos   HistoricoStatus[]
  autorizacoes Autorizacao[]

  @@map("encomenda")
}

model HistoricoStatus {
  id            Int      @id @default(autoincrement())
  encomendaId   Int      @map("encomenda_id")
  statusId      Int      @map("status_id")
  alteradoPorId Int      @map("alterado_por")
  dataAlteracao DateTime @default(now()) @map("data_alteracao")

  encomenda   Encomenda       @relation(fields: [encomendaId], references: [id])
  status      StatusEncomenda @relation(fields: [statusId], references: [id])
  alteradoPor Usuario         @relation(fields: [alteradoPorId], references: [id])

  @@map("historicocostatus")
}

// ---------------------------------------------------------------------------
// DESTINATÁRIOS E AUTORIZAÇÕES
// ---------------------------------------------------------------------------

model Destinatario {
  id           Int        @id @default(autoincrement())
  usuarioId    Int        @map("usuario_id")
  nomeCompleto String     @map("nome_completo") @db.VarChar(150)
  documento    String?    @db.VarChar(20)
  parentesco   Parentesco
  ativo        Boolean    @default(true)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  usuario      Usuario       @relation(fields: [usuarioId], references: [id])
  autorizacoes Autorizacao[]

  @@map("destinatarios")
}

enum Parentesco {
  proprio
  pai
  mae
  irmao
  irma
  responsavel
  outro

  @@map("parentesco")
}

model Autorizacao {
  id             Int       @id @default(autoincrement())
  encomendaId    Int       @map("encomenda_id")
  destinatarioId Int?      @map("destinatario_id")  // nulo se for nome avulso
  nomeAvulso     String?   @map("nome_avulso") @db.VarChar(150)
  documento      String?   @db.VarChar(20)
  autorizadoPorId Int      @map("autorizado_por")
  validade       DateTime?
  utilizada      Boolean   @default(false)
  createdAt      DateTime  @default(now()) @map("created_at")

  encomenda    Encomenda    @relation(fields: [encomendaId], references: [id])
  destinatario Destinatario? @relation(fields: [destinatarioId], references: [id])
  autorizadoPor Usuario      @relation(fields: [autorizadoPorId], references: [id])

  @@map("autorizacoes")
}

// ---------------------------------------------------------------------------
// NOTIFICAÇÕES E AUDITORIA
// ---------------------------------------------------------------------------

model Notificacao {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @map("usuario_id")
  tipo      String   @db.VarChar(20)
  mensagem  String   @db.VarChar(255)
  lida      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("notificacao")
}

model Auditoria {
  id         Int      @id @default(autoincrement())
  usuarioId  Int      @map("usuario_id")
  entidade   String   @db.VarChar(100)
  entidadeId Int      @map("entidade_id")
  acao       String   @db.VarChar(50)
  descricao  String?  @db.Text
  ipUsuario  String?  @map("ip_usuario") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("auditoria")
}
