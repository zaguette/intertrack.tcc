generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id                  String            @id @db.Char(36)
  codigo              String            @unique @default(cuid())
  nome                String            @db.VarChar(100)
  email               String            @unique @db.VarChar(100)
  senha               String            @db.VarChar(255)
  telefone            String?           @db.VarChar(30)
  ativo               Boolean           @default(true)
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt
  autorizacoesCriadas Autorizacao[]
  encomendas          Encomenda[]
  nomesAlternativos   NomeAlternativo[]
  notificacoes        Notificacao[]
}

model Funcionario {
  id         String            @id @db.Char(36)
  codigo     String            @unique @default(cuid())
  nome       String            @db.VarChar(100)
  email      String            @unique @db.VarChar(100)
  senha      String            @db.VarChar(255)
  telefone   String?           @db.VarChar(30)
  cargo      CargoFuncionario  @default(recebimento)
  ativo      Boolean           @default(true)
  created_at DateTime          @default(now())
  updated_at DateTime          @updatedAt
  auditorias Auditoria[]
  encomendas Encomenda[]
  historicos HistoricoStatus[]
}

model StatusEncomenda {
  id          String            @id @db.Char(36)
  codigo      String            @unique @default(cuid())
  nome_status String            @db.VarChar(50)
  descricao   String?           @db.VarChar(255)
  encomendas  Encomenda[]
  historicos  HistoricoStatus[]
}

model Remetente {
  id         String        @id @db.Char(36)
  codigo     String        @unique @default(cuid())
  nome       String        @db.VarChar(100)
  tipo       TipoRemetente @default(outro)
  site       String?       @db.VarChar(255)
  created_at DateTime      @default(now())
  encomendas Encomenda[]
}

model NomeAlternativo {
  id            String        @id @db.Char(36)
  codigo        String        @unique @default(cuid())
  usuario_id    String        @db.Char(36)
  nome_completo String        @db.VarChar(150)
  documento     String?       @db.VarChar(20)
  parentesco    Parentesco    @default(outro)
  ativo         Boolean       @default(true)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  autorizacoes  Autorizacao[]
  usuario       Usuario       @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([usuario_id], map: "NomeAlternativo_usuario_id_fkey")
}

model Encomenda {
  id                      String            @id @db.Char(36)
  codigo                  String            @unique @default(cuid())
  codigo_rastreio         String?           @db.VarChar(50)
  descricao               String?           @db.VarChar(255)
  destinatario_usuario_id String            @db.Char(36)
  remetente_id            String?           @db.Char(36)
  funcionario_id          String            @db.Char(36)
  status_atual_id         String            @db.Char(36)
  data_entrega            DateTime?
  observacoes             String?           @db.Text
  created_at              DateTime          @default(now())
  updated_at              DateTime          @updatedAt
  autorizacoes            Autorizacao[]
  destinatario            Usuario           @relation(fields: [destinatario_usuario_id], references: [id])
  funcionario             Funcionario       @relation(fields: [funcionario_id], references: [id])
  remetente               Remetente?        @relation(fields: [remetente_id], references: [id])
  statusAtual             StatusEncomenda   @relation(fields: [status_atual_id], references: [id])
  historicos              HistoricoStatus[]
  notificacoes            Notificacao[]

  @@index([codigo_rastreio])
  @@index([destinatario_usuario_id])
  @@index([funcionario_id], map: "Encomenda_funcionario_id_fkey")
  @@index([remetente_id], map: "Encomenda_remetente_id_fkey")
  @@index([status_atual_id], map: "Encomenda_status_atual_id_fkey")
}

model HistoricoStatus {
  id             String          @id @db.Char(36)
  codigo         String          @unique @default(cuid())
  encomenda_id   String          @db.Char(36)
  status_id      String          @db.Char(36)
  alterado_por   String          @db.Char(36)
  data_alteracao DateTime        @default(now())
  funcionario    Funcionario     @relation(fields: [alterado_por], references: [id])
  encomenda      Encomenda       @relation(fields: [encomenda_id], references: [id], onDelete: Cascade)
  status         StatusEncomenda @relation(fields: [status_id], references: [id])

  @@index([encomenda_id])
  @@index([alterado_por], map: "HistoricoStatus_alterado_por_fkey")
  @@index([status_id], map: "HistoricoStatus_status_id_fkey")
}

model Notificacao {
  id           String    @id @db.Char(36)
  codigo       String    @unique @default(cuid())
  usuario_id   String    @db.Char(36)
  encomenda_id String    @db.Char(36)
  tipo         String?   @db.VarChar(20)
  mensagem     String?   @db.VarChar(255)
  lida         Boolean   @default(false)
  created_at   DateTime  @default(now())
  encomenda    Encomenda @relation(fields: [encomenda_id], references: [id], onDelete: Cascade)
  usuario      Usuario   @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@index([usuario_id])
  @@index([encomenda_id], map: "Notificacao_encomenda_id_fkey")
}

model Autorizacao {
  id              String           @id @db.Char(36)
  codigo          String           @unique @default(cuid())
  encomenda_id    String           @db.Char(36)
  destinatario_id String?          @db.Char(36)
  nome_avulso     String?          @db.VarChar(150)
  documento       String?          @db.VarChar(20)
  autorizado_por  String           @db.Char(36)
  validade        DateTime?
  utilizada       Boolean          @default(false)
  created_at      DateTime         @default(now())
  autorizadoPor   Usuario          @relation(fields: [autorizado_por], references: [id])
  destinatario    NomeAlternativo? @relation(fields: [destinatario_id], references: [id])
  encomenda       Encomenda        @relation(fields: [encomenda_id], references: [id], onDelete: Cascade)

  @@index([encomenda_id])
  @@index([autorizado_por], map: "Autorizacao_autorizado_por_fkey")
  @@index([destinatario_id], map: "Autorizacao_destinatario_id_fkey")
}

model Auditoria {
  id             String      @id @db.Char(36)
  codigo         String      @unique @default(cuid())
  funcionario_id String      @db.Char(36)
  entidade       String?     @db.VarChar(100)
  entidade_id    String?     @db.Char(36)
  acao           String?     @db.VarChar(50)
  descricao      String?     @db.Text
  ip_usuario     String?     @db.VarChar(45)
  created_at     DateTime    @default(now())
  funcionario    Funcionario @relation(fields: [funcionario_id], references: [id])

  @@index([funcionario_id], map: "Auditoria_funcionario_id_fkey")
}

enum CargoFuncionario {
  recebimento
  administrador
  porteiro
  supervisor
}

enum TipoRemetente {
  correios
  transportadora
  ecommerce
  outro
}

enum Parentesco {
  pai
  mae
  irmao
  irma
  responsavel
  outro
}
